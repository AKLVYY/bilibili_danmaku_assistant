     <property name="styleSheet">
      <string notr="true">QPushButton {
    background-color: #FB7299; /* B站标准粉色 */
    color: white; /* 纯白文字，保证高对比度 */
    font-weight: bold; /* 字体加粗 */
    font-size: 16px; /* 字号加大，突出主炮地位 */
    border-radius: 8px; /* 圆滑的装甲边缘 */
    padding: 10px; /* 增加内边距，让按钮看起来更丰满 */
    border: none; /* 去除默认的丑陋黑边 */
}

QPushButton:hover {
    background-color: #ff85a8; /* 鼠标悬停时稍微变亮，增加交互感 */
}

QPushButton:pressed {
    background-color: #e06085; /* 按下时颜色变深，体现机械按压感 */
}</string>
     </property>
